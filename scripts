#!/usr/bin/env python3
"""
Đo độ dài thật của 4 file audio (đã sinh bằng `hyperframes tts`) rồi thay
các placeholder __D1__..__D4__ và __TOTAL__ trong index.html bằng số thật.
Chạy SAU bước TTS, TRƯỚC bước lint/render trong workflow.
"""
import json
import subprocess
import sys

AUDIO_FILES = [
    "assets/voice-1.wav",
    "assets/voice-2.wav",
    "assets/voice-3.wav",
    "assets/voice-4.wav",
]


def ffprobe_duration(path: str) -> float:
    out = subprocess.run(
        [
            "ffprobe",
            "-v", "quiet",
            "-show_entries", "format=duration",
            "-of", "json",
            path,
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    data = json.loads(out.stdout)
    return float(data["format"]["duration"])


def main() -> None:
    durations = [ffprobe_duration(p) for p in AUDIO_FILES]
    total = sum(durations)

    print("Measured narration durations (seconds):")
    for i, d in enumerate(durations, start=1):
        print(f"  voice-{i}.wav -> {d:.2f}s")
    print(f"  TOTAL -> {total:.2f}s")

    with open("index.html", "r", encoding="utf-8") as f:
        html = f.read()

    for i, d in enumerate(durations, start=1):
        token = f"__D{i}__"
        if token not in html:
            print(f"ERROR: token {token} not found in index.html", file=sys.stderr)
            sys.exit(1)
        html = html.replace(token, f"{d:.3f}")

    if "__TOTAL__" not in html:
        print("ERROR: token __TOTAL__ not found in index.html", file=sys.stderr)
        sys.exit(1)
    html = html.replace("__TOTAL__", f"{total:.3f}")

    with open("index.html", "w", encoding="utf-8") as f:
        f.write(html)

    print("index.html updated with real durations.")


if __name__ == "__main__":
    main()
